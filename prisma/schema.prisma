generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum ArticleStatus {
  draft
  published
  archived
}

enum ArticleSourceType {
  original
  hermes
  imported
}

enum LeadStatus {
  new
  contacted
  qualified
  won
  lost
}

enum PostlyContentStatus {
  PLANNED
  DRAFT_GENERATED
  WAITING_APPROVAL
  APPROVED
  REJECTED
  NEEDS_REVISION
  SENT_TO_MAKE
  MEDIA_GENERATED
  SCHEDULED
  POSTED
  FAILED
}

enum PostlyPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum PostlyTemplateStatus {
  ACTIVE
  INACTIVE
}

enum PostlyProductStatus {
  ACTIVE
  INACTIVE
}

enum PostlyApprovalStatus {
  WAITING
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum PostlyPostingStatus {
  PENDING
  SENT_TO_MAKE
  SCHEDULED
  POSTED
  FAILED
}

enum PostlyPlatform {
  FACEBOOK
  INSTAGRAM
}

enum PostlyContentType {
  CAROUSEL
  REEL
  POSTER
  STORY
}

enum PostlyAssetType {
  IMAGE
  VIDEO
  CAROUSEL_SLIDE
  REEL_COVER
}

enum PostlyAssetSource {
  UPLOADED
  GENERATED
  MAKE
  HERMES
}

enum PostlySocialStatus {
  CONNECTED
  EXPIRED
  DISCONNECTED
}

model User {
  id          String    @id @default(cuid())
  clerkUserId String    @unique
  email       String    @unique
  name        String?
  phone       String?
  country     String?
  city        String?
  currentWork String?
  locale      String    @default("en")
  role        UserRole  @default(user)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastSeenAt  DateTime?

  articleViews       ArticleView[]
  pageEvents         PageEvent[]
  newsletters        NewsletterSubscriber[]
  crmNotes           CrmNote[]              @relation("CrmNoteUser")
  academyEnrollments AcademyEnrollment[]
  companyProfile     CompanyProfile?
  createdPostlyPlans ContentPlan[]          @relation("ContentPlanCreator")
}

model CompanyProfile {
  id                String   @id @default(cuid())
  userId            String?  @unique
  clerkUserId       String   @unique
  companyName       String?
  businessType      String?
  activityDirection String?
  description       String?
  phone             String?
  email             String?
  website           String?
  address           String?
  workingHours      String?
  facebookUrl       String?
  instagramUrl      String?
  tiktokUrl         String?
  productsServices  String[] @default([])
  logoUrl           String?
  plan              String   @default("Starter")
  postingFrequency  String?
  postingTime       String?
  postingDays       String[] @default([])
  contentMix        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user                   User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandGuideline         BrandGuideline?
  brandTemplates         BrandTemplate[]
  productsServicesPostly ProductService[]
  contentPlans           ContentPlan[]
  contentItems           ContentItem[]
  contentAssets          ContentAsset[]
  postingJobs            PostingJob[]
  postingLogs            PostingLog[]
  socialAccounts         SocialAccount[]
  makeIntegration        MakeIntegration?
  agentLogs              AgentLog[]

  @@index([clerkUserId])
}

model BrandGuideline {
  id             String   @id @default(cuid())
  companyId      String   @unique
  toneOfVoice    String?
  brandColors    String[] @default([])
  fonts          String[] @default([])
  logoUrl        String?
  forbiddenWords String[] @default([])
  preferredWords String[] @default([])
  ctaStyle       String?
  visualStyle    String?
  language       String   @default("mn")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model BrandTemplate {
  id              String               @id @default(cuid())
  companyId       String
  name            String
  type            PostlyContentType
  category        String?
  templateFileUrl String?
  previewImageUrl String?
  editableFields  Json?
  size            String?
  status          PostlyTemplateStatus @default(ACTIVE)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  company      CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contentItems ContentItem[]

  @@index([companyId, status])
  @@index([companyId, type])
}

model ProductService {
  id             String              @id @default(cuid())
  companyId      String
  name           String
  description    String?
  price          String?
  benefits       String[]            @default([])
  targetCustomer String?
  painPoints     String[]            @default([])
  status         PostlyProductStatus @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

model ContentPlan {
  id             String           @id @default(cuid())
  companyId      String
  month          String
  totalCarousels Int              @default(0)
  totalReels     Int              @default(0)
  totalPosts     Int              @default(0)
  strategyNote   String?
  status         PostlyPlanStatus @default(DRAFT)
  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  company      CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User?          @relation("ContentPlanCreator", fields: [createdById], references: [id], onDelete: SetNull)
  contentItems ContentItem[]

  @@index([companyId, month])
  @@index([companyId, status])
}

model ContentItem {
  id                String              @id @default(cuid())
  companyId         String
  contentPlanId     String?
  templateId        String?
  contentType       PostlyContentType
  category          String?
  title             String?
  caption           String?
  headline          String?
  imagePrompt       String?
  creativeDirection String?
  scheduledAt       DateTime?
  status            PostlyContentStatus @default(PLANNED)
  telegramMessageId String?
  makeStatus        String?
  facebookPostUrl   String?
  instagramPostUrl  String?
  errorMessage      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  company          CompanyProfile    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contentPlan      ContentPlan?      @relation(fields: [contentPlanId], references: [id], onDelete: SetNull)
  template         BrandTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  assets           ContentAsset[]
  approvalRequests ApprovalRequest[]
  postingJobs      PostingJob[]
  postingLogs      PostingLog[]
  agentLogs        AgentLog[]

  @@index([companyId, status])
  @@index([contentPlanId, contentType])
  @@index([scheduledAt])
}

model ContentAsset {
  id            String            @id @default(cuid())
  companyId     String
  contentItemId String
  assetType     PostlyAssetType
  fileUrl       String
  source        PostlyAssetSource @default(UPLOADED)
  slideOrder    Int?
  status        String            @default("ready")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contentItem ContentItem    @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([contentItemId, assetType])
}

model ApprovalRequest {
  id                String               @id @default(cuid())
  contentItemId     String
  telegramChatId    String?
  telegramMessageId String?
  status            PostlyApprovalStatus @default(WAITING)
  approvedAt        DateTime?
  revisionNote      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([contentItemId, status])
  @@index([telegramMessageId])
}

model PostingJob {
  id                  String              @id @default(cuid())
  companyId           String
  contentItemId       String
  platform            PostlyPlatform
  scheduledAt         DateTime?
  status              PostlyPostingStatus @default(PENDING)
  makeWebhookResponse Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contentItem ContentItem    @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([contentItemId, platform])
}

model PostingLog {
  id            String          @id @default(cuid())
  companyId     String
  contentItemId String?
  platform      PostlyPlatform?
  status        String
  postedUrl     String?
  errorMessage  String?
  rawResponse   Json?
  createdAt     DateTime        @default(now())

  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contentItem ContentItem?   @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([contentItemId, createdAt])
}

model SocialAccount {
  id                   String             @id @default(cuid())
  companyId            String
  platform             PostlyPlatform
  pageName             String?
  pageId               String?
  instagramAccountId   String?
  accessTokenEncrypted String?
  status               PostlySocialStatus @default(DISCONNECTED)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, platform])
}

model MakeIntegration {
  id                String   @id @default(cuid())
  companyId         String   @unique
  webhookUrl        String?
  webhookSecretHint String?
  scenarioName      String?
  status            String   @default("inactive")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AgentLog {
  id            String   @id @default(cuid())
  companyId     String?
  contentItemId String?
  agentName     String
  action        String
  status        String
  message       String?
  rawPayload    Json?
  createdAt     DateTime @default(now())

  company     CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contentItem ContentItem?    @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([contentItemId, createdAt])
  @@index([agentName, action])
}

model Article {
  id                 String            @id @default(cuid())
  slug               String            @unique
  status             ArticleStatus     @default(draft)
  sourceType         ArticleSourceType @default(original)
  canonicalSourceUrl String?
  sourceName         String?
  coverImage         String?
  imageAltEn         String?
  imageAltMn         String?
  category           String
  industrySlug       String?
  dailyRank          Int?
  readTime           Int               @default(4)
  titleEn            String
  titleMn            String
  excerptEn          String
  excerptMn          String
  bodyEn             String
  bodyMn             String
  seoTitleEn         String?
  seoTitleMn         String?
  seoDescriptionEn   String?
  seoDescriptionMn   String?
  tags               String[]          @default([])
  importanceScore    Int?
  publishedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  views ArticleView[]

  @@index([industrySlug, publishedAt])
}

model ArticleView {
  id          String   @id @default(cuid())
  articleId   String
  userId      String?
  sessionId   String?
  locale      String
  percentRead Int      @default(0)
  timeOnPage  Int      @default(0)
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
}

model NewsletterSubscriber {
  id               String   @id @default(cuid())
  email            String   @unique
  locale           String   @default("en")
  consent          Boolean  @default(false)
  unsubscribeToken String   @unique
  userId           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  clicks NewsletterClick[]
  notes  CrmNote[]         @relation("CrmNoteSubscriber")
}

model QuoteRequest {
  id              String     @id @default(cuid())
  name            String
  company         String?
  email           String
  serviceInterest String
  message         String
  locale          String     @default("en")
  status          LeadStatus @default(new)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  notes CrmNote[] @relation("CrmNoteQuote")
}

model DemoLead {
  id          String     @id @default(cuid())
  industry    String
  companyName String
  contactName String
  phone       String
  email       String
  locale      String     @default("en")
  path        String?
  referrer    String?
  userAgent   String?
  status      LeadStatus @default(new)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([email, createdAt])
  @@index([industry, createdAt])
}

model CrmNote {
  id           String   @id @default(cuid())
  body         String
  createdAt    DateTime @default(now())
  authorUserId String?
  userId       String?
  subscriberId String?
  quoteId      String?

  author     User?                 @relation("CrmNoteUser", fields: [authorUserId], references: [id], onDelete: SetNull)
  subscriber NewsletterSubscriber? @relation("CrmNoteSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  quote      QuoteRequest?         @relation("CrmNoteQuote", fields: [quoteId], references: [id], onDelete: Cascade)
}

model PageEvent {
  id                String   @id @default(cuid())
  userId            String?
  sessionId         String?
  locale            String?
  path              String
  eventType         String
  referrer          String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  newsletterClickId String?
  durationSeconds   Int?
  metadata          Json?
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([path, createdAt])
  @@index([userId, createdAt])
}

model NewsletterCampaign {
  id        String    @id @default(cuid())
  subjectEn String
  subjectMn String
  briefEn   String
  briefMn   String
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  clicks NewsletterClick[]
}

model NewsletterClick {
  id           String    @id @default(cuid())
  campaignId   String
  subscriberId String?
  articleSlug  String
  locale       String
  token        String    @unique
  clickedAt    DateTime?
  createdAt    DateTime  @default(now())

  campaign   NewsletterCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriber NewsletterSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
}

model AcademyEnrollment {
  id          String   @id @default(cuid())
  userId      String?
  clerkUserId String?
  email       String
  phone       String?
  firstName   String?
  lastName    String?
  fullName    String?
  country     String?
  city        String?
  currentWork String?
  courseId    String
  courseName  String
  plan        String?
  price       String?
  currency    String?
  locale      String   @default("en")
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  referrer    String?
  landingPage String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([clerkUserId, courseId])
  @@index([email, createdAt])
  @@index([clerkUserId, createdAt])
}

model HermesWebhookDelivery {
  id             String   @id @default(cuid())
  event          String
  idempotencyKey String   @unique
  source         String
  status         String   @default("pending")
  attempts       Int      @default(0)
  lastError      String?
  lastStatusCode Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
