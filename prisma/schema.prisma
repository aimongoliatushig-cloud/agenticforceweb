generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum ArticleStatus {
  draft
  published
  archived
}

enum ArticleSourceType {
  original
  hermes
  imported
}

enum LeadStatus {
  new
  contacted
  qualified
  won
  lost
}

model User {
  id           String    @id @default(cuid())
  clerkUserId  String    @unique
  email        String    @unique
  name         String?
  phone        String?
  country      String?
  city         String?
  currentWork  String?
  locale       String    @default("en")
  role         UserRole  @default(user)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSeenAt   DateTime?

  articleViews ArticleView[]
  pageEvents   PageEvent[]
  newsletters  NewsletterSubscriber[]
  crmNotes     CrmNote[] @relation("CrmNoteUser")
  academyEnrollments AcademyEnrollment[]
}

model Article {
  id                 String            @id @default(cuid())
  slug               String            @unique
  status             ArticleStatus     @default(draft)
  sourceType         ArticleSourceType @default(original)
  canonicalSourceUrl String?
  sourceName         String?
  coverImage         String?
  imageAltEn         String?
  imageAltMn         String?
  category           String
  industrySlug       String?
  dailyRank          Int?
  readTime           Int               @default(4)
  titleEn            String
  titleMn            String
  excerptEn          String
  excerptMn          String
  bodyEn             String
  bodyMn             String
  seoTitleEn         String?
  seoTitleMn         String?
  seoDescriptionEn   String?
  seoDescriptionMn   String?
  tags               String[]          @default([])
  importanceScore    Int?
  publishedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  views ArticleView[]

  @@index([industrySlug, publishedAt])
}

model ArticleView {
  id          String   @id @default(cuid())
  articleId   String
  userId      String?
  sessionId   String?
  locale      String
  percentRead Int      @default(0)
  timeOnPage  Int      @default(0)
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
}

model NewsletterSubscriber {
  id               String    @id @default(cuid())
  email            String    @unique
  locale           String    @default("en")
  consent          Boolean   @default(false)
  unsubscribeToken String    @unique
  userId           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  clicks NewsletterClick[]
  notes  CrmNote[] @relation("CrmNoteSubscriber")
}

model QuoteRequest {
  id              String     @id @default(cuid())
  name            String
  company         String?
  email           String
  serviceInterest String
  message         String
  locale          String     @default("en")
  status          LeadStatus @default(new)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  notes CrmNote[] @relation("CrmNoteQuote")
}

model DemoLead {
  id          String     @id @default(cuid())
  industry    String
  companyName String
  contactName String
  phone       String
  email       String
  locale      String     @default("en")
  path        String?
  referrer    String?
  userAgent   String?
  status      LeadStatus @default(new)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([email, createdAt])
  @@index([industry, createdAt])
}

model CrmNote {
  id           String   @id @default(cuid())
  body         String
  createdAt    DateTime @default(now())
  authorUserId String?
  userId       String?
  subscriberId String?
  quoteId      String?

  author     User?                 @relation("CrmNoteUser", fields: [authorUserId], references: [id], onDelete: SetNull)
  subscriber NewsletterSubscriber? @relation("CrmNoteSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  quote      QuoteRequest?         @relation("CrmNoteQuote", fields: [quoteId], references: [id], onDelete: Cascade)
}

model PageEvent {
  id                String   @id @default(cuid())
  userId            String?
  sessionId         String?
  locale            String?
  path              String
  eventType         String
  referrer          String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  newsletterClickId String?
  durationSeconds   Int?
  metadata          Json?
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([path, createdAt])
  @@index([userId, createdAt])
}

model NewsletterCampaign {
  id        String   @id @default(cuid())
  subjectEn String
  subjectMn String
  briefEn   String
  briefMn   String
  sentAt    DateTime?
  createdAt DateTime @default(now())

  clicks NewsletterClick[]
}

model NewsletterClick {
  id           String   @id @default(cuid())
  campaignId   String
  subscriberId String?
  articleSlug  String
  locale       String
  token        String   @unique
  clickedAt    DateTime?
  createdAt    DateTime @default(now())

  campaign   NewsletterCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriber NewsletterSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
}

model AcademyEnrollment {
  id          String   @id @default(cuid())
  userId      String?
  clerkUserId String?
  email       String
  phone       String?
  firstName   String?
  lastName    String?
  fullName    String?
  country     String?
  city        String?
  currentWork String?
  courseId    String
  courseName  String
  plan        String?
  price       String?
  currency    String?
  locale      String   @default("en")
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  referrer    String?
  landingPage String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([clerkUserId, createdAt])
  @@unique([clerkUserId, courseId])
}

model HermesWebhookDelivery {
  id             String   @id @default(cuid())
  event          String
  idempotencyKey String   @unique
  source         String
  status         String   @default("pending")
  attempts       Int      @default(0)
  lastError      String?
  lastStatusCode Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── Postly Content Management ──

enum ContentItemStatus {
  PLANNED
  DRAFT
  WAITING_APPROVAL
  APPROVED
  SENT_TO_MAKE
  MEDIA_GENERATED
  POSTED
  REJECTED
}

enum ContentType {
  CAROUSEL
  POSTER
  REEL
}

model PostlyBrand {
  id             String   @id @default(cuid())
  companyId      String?
  brandName      String   @unique
  businessType   String?
  brandGuideline Json?    @default("{}")
  products       Json?    @default("[]")
  templates      Json?    @default("[]")
  socialAccounts Json?    @default("[]")
  makeIntegration Json?   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contentPlans PostlyContentPlan[]
  contentItems PostlyContentItem[]

  @@index([brandName])
}

model PostlyContentPlan {
  id            String   @id @default(cuid())
  brandId       String
  monthYear     String   // e.g. "2026-06"
  status        String   @default("active")
  strategyNote  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  brand        PostlyBrand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contentItems PostlyContentItem[]

  @@index([brandId, monthYear])
}

model PostlyContentItem {
  id              String            @id @default(cuid())
  contentPlanId   String
  brandId         String
  companyId       String?

  contentType     ContentType       @default(POSTER)
  category        String?           // education, promo, smoke_test, etc.
  title           String?
  caption         String?
  headline        String?
  imagePrompt     String?
  creativeDirection String?
  templateId      String?

  agentName       String?           // which Hermes agent generated this
  telegramMessageId String?         // Telegram approval message ID
  telegramChatId  String?           // Telegram chat ID for approval

  status          ContentItemStatus @default(PLANNED)
  makeStatus      String?           // from Make.com callback
  revisionNote    String?           // from admin revision

  assets          Json?             @default("[]")
  postingJobs     Json?             @default("[]")
  approvalHistory Json?             @default("[]")

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  brand        PostlyBrand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  contentPlan  PostlyContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)

  @@index([brandId, status])
  @@index([status, createdAt])
}

model PostlyOperationalLog {
  id        String   @id @default(cuid())
  event     String   // fetch_planned, generate_draft, send_approval, approval_received, sent_to_make, error
  brandId   String?
  itemId    String?
  status    String   @default("success")
  message   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event, createdAt])
}
